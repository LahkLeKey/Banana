{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Native: configure (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "src/native",
        "-B",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Native: build (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: configure (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: continuity suite (v3)",
      "type": "shell",
      "command": "ctest",
      "args": [
        "-C",
        "Debug",
        "--test-dir",
        "out/v3-native",
        "-R",
        "banana_runtime_demo_scene_catalog_(coherent_profile_test|transition_continuity_test|continuity_roundtrip_test)",
        "--output-on-failure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "API: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import { registerHealthRoutes } from \"./src/typescript/api/src/routes/health.ts\"; console.log(typeof registerHealthRoutes);"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "UI: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import \"./src/typescript/shared/ui/src/index.ts\"; console.log(\"ui-contract-ok\");"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: up (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d",
        "api-overworld",
        "react-overworld"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: down (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: logs (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "logs",
        "-f",
        "api-overworld",
        "react-overworld"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: up (native neon integration compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "--profile",
        "integration",
        "up",
        "--build",
        "native-neon-integration"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: down (native neon integration compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "--profile",
        "integration",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
