{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Native: configure (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "src/native",
        "-B",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Native: build (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: configure (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: continuity suite (v3)",
      "type": "shell",
      "command": "ctest",
      "args": [
        "-C",
        "Debug",
        "--test-dir",
        "out/v3-native",
        "-R",
        "banana_runtime_demo_scene_catalog_(coherent_profile_test|transition_continuity_test|continuity_roundtrip_test)",
        "--output-on-failure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (focused)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --suite focused"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (evidence)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --suite evidence"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (soak)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --suite soak"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (legacy)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --suite legacy"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (single test prompt)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --suite none --test \"${input:warCtestName}\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Native: war suite (custom regex prompt)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/run-war-test-suites.sh --regex \"${input:warCtestRegex}\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: build (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "API: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import { registerHealthRoutes } from \"./src/typescript/api/src/routes/health.ts\"; console.log(typeof registerHealthRoutes);"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "UI: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import \"./src/typescript/shared/ui/src/index.ts\"; console.log(\"ui-contract-ok\");"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: up (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d",
        "api-overworld",
        "react-overworld"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: down (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: logs (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "logs",
        "-f",
        "api-overworld",
        "react-overworld"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: up (native neon integration compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "--profile",
        "integration",
        "up",
        "--build",
        "native-neon-integration"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: down (native neon integration compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "--profile",
        "integration",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ],
  "inputs": [
    {
      "id": "warCtestName",
      "type": "promptString",
      "description": "ctest name to run (example: banana_runtime_gameplay_warfront_comeback_bonus_test)"
    },
    {
      "id": "warCtestRegex",
      "type": "promptString",
      "description": "ctest regex pattern",
      "default": "banana_(runtime_gameplay_warfront_expansion|runtime_gameplay_warfront_comeback_bonus|runtime_tick_orchestration_war_long_run_soak|runtime_full_mmo_demo)_test"
    }
  ]
}
