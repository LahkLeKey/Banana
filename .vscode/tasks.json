{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Native: configure (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "src/native",
        "-B",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Native: build (v3)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "out/v3-native"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Native: configure (v3)",
      "dependsOrder": "sequence"
    },
    {
      "label": "API: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import { apiScaffold } from './src/typescript/api/src/index.ts'; console.log(apiScaffold);"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "UI: smoke (v3)",
      "type": "shell",
      "command": "bun",
      "args": [
        "-e",
        "import { uiScaffold } from './src/typescript/shared/ui/src/index.ts'; console.log(uiScaffold);"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: up (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d",
        "api-overworld",
        "react-overworld"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: down (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Runtime: logs (overworld compose)",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "logs",
        "-f",
        "api-overworld",
        "react-overworld"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
