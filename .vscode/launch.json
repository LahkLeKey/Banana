{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Banana Full Stack (Compose Up)",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash -lc 'DETACH=1 scripts/compose-apps.sh'"
    },
    {
      "name": "Banana Full Stack (Browser)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/typescript/react"
    },
    {
      "name": "Banana Full Stack (Compose Down)",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/compose-apps-down.sh"
    }
  ],
  "compounds": [
    {
      "name": "Banana Full Stack (One Click)",
      "configurations": [
        "Banana Full Stack (Compose Up)",
        "Banana Full Stack (Browser)"
      ],
      "stopAll": true
    }
  ]
}