{
    "version": "0.2.0",
    "compounds": [
        {
            "name": "Frontends: API + React",
            "configurations": ["Compose: apps profile"],
            "stopAll": true,
            "presentation": { "group": "frontends", "order": 1 }
        },
        {
            "name": "Frontends: API + Electron",
            "configurations": ["Compose: electron-desktop profile"],
            "stopAll": true,
            "presentation": { "group": "frontends", "order": 2 }
        },
        {
            "name": "Frontends: API + React Native (web)",
            "configurations": ["Compose: mobile profile"],
            "stopAll": true,
            "presentation": { "group": "frontends", "order": 3 }
        },
        {
            "name": "Train: all (ci profile)",
            "configurations": [
                "Train: not-banana (ci profile)",
                "Train: banana (ci profile)",
                "Train: ripeness (ci profile)"
            ],
            "stopAll": true,
            "presentation": { "group": "training", "order": 1 }
        }
    ],
    "configurations": [
        {
            "name": "Compose: runtime profile",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash -lc cat",
            "cwd": "${workspaceFolder:(Monorepo) Banana}/src/typescript/api",
            "preLaunchTask": "Compose: runtime up + ready",
            "postDebugTask": "Compose: runtime down",
            "presentation": { "group": "frontends", "order": 10 }
        },
        {
            "name": "Compose: apps profile",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash -lc cat",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "preLaunchTask": "Compose: frontend react up + ready",
            "postDebugTask": "Compose: frontend react down",
            "presentation": { "group": "frontends", "order": 11 }
        },
        {
            "name": "Compose: electron-desktop profile",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash -lc cat",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "preLaunchTask": "Compose: frontend electron up + ready",
            "postDebugTask": "Compose: frontend electron down",
            "presentation": { "group": "frontends", "order": 12 }
        },
        {
            "name": "Compose: mobile profile",
            "type": "node-terminal",
            "request": "launch",
            "command": "bash -lc cat",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "preLaunchTask": "Compose: frontend mobile up + ready",
            "postDebugTask": "Compose: frontend mobile down",
            "presentation": { "group": "frontends", "order": 13 }
        },
        {
            "name": "Train: not-banana (ci profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-not-banana-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/not-banana/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/not-banana/local",
                "--training-profile", "ci",
                "--session-mode", "single",
                "--max-sessions", "1"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 20 }
        },
        {
            "name": "Train: not-banana (local profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-not-banana-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/not-banana/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/not-banana/local",
                "--training-profile", "local"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 21 }
        },
        {
            "name": "Train: banana (ci profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-banana-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/banana/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/banana/local",
                "--training-profile", "ci",
                "--session-mode", "single",
                "--max-sessions", "1"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 22 }
        },
        {
            "name": "Train: banana (local profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-banana-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/banana/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/banana/local",
                "--training-profile", "local"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 23 }
        },
        {
            "name": "Train: ripeness (ci profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-ripeness-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/ripeness/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/ripeness/local",
                "--training-profile", "ci",
                "--session-mode", "single",
                "--max-sessions", "1"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 24 }
        },
        {
            "name": "Train: ripeness (local profile)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder:(Monorepo) Banana}/scripts/train-ripeness-model.py",
            "cwd": "${workspaceFolder:(Monorepo) Banana}",
            "args": [
                "--corpus", "data/ripeness/corpus.json",
                "--output", "${workspaceFolder:(Monorepo) Banana}/artifacts/training/ripeness/local",
                "--training-profile", "local"
            ],
            "console": "integratedTerminal",
            "presentation": { "group": "training", "order": 25 }
        }
    ]
}
