# Copy this file to .env and fill in real values for local workflow-container runs.
# Docker Compose in this repo auto-loads .env from the repository root.

# Required for real PR creation in local workflow containers.
GH_TOKEN=

# Set to false for real PR creation; true keeps dry-run mode.
BANANA_LOCAL_DRY_RUN=false

# Reviewer assignment (GitHub usernames only; supports comma-separated or [array] syntax).
BANANA_REGISTRY_PR_REVIEWERS=LahkLeKey,Zephyr,copilot
BANANA_PR_REVIEWERS=["LahkLeKey","Zephyr","copilot-pull-request-reviewer"]

# Optional PR routing defaults.
BANANA_REGISTRY_PR_BASE_BRANCH=main
BANANA_REGISTRY_OPEN_DRAFT_PR=true
BANANA_DRAFT_PR=true
BANANA_BASE_BRANCH=main
BANANA_BRANCH_PREFIX=sdlc

# Optional SDLC orchestration defaults for workflow-orchestrate-sdlc.*
BANANA_SDLC_ID=banana-sdlc
BANANA_SDLC_INCREMENT_PLAN_JSON=
BANANA_SDLC_SKIP_NO_CHANGES=true
BANANA_SDLC_CONTINUE_ON_ERROR=false
BANANA_SDLC_ENABLE_WIKI_SYNC=true

# Optional feedback-oversight defaults for feedback-loop orchestration.
BANANA_FEEDBACK_REQUIRE_HUMAN_REVIEW=true
BANANA_FEEDBACK_MIN_HUMAN_REVIEWERS=1

# Optional wiki sync defaults for SDLC runs.
BANANA_WIKI_DRY_RUN=true
BANANA_WIKI_PUSH=false
BANANA_WIKI_STRICT=false
BANANA_WIKI_DIR=artifacts/wiki-sync/local-wiki-dry-run
# Banana canonical wiki remote; override this value when running from a fork.
BANANA_WIKI_REMOTE_URL=https://github.com/LahkLeKey/Banana.wiki.git
BANANA_WIKI_CANONICAL_REMOTE_URL=https://github.com/LahkLeKey/Banana.wiki.git
BANANA_ENFORCE_CANONICAL_WIKI_REMOTE=true
BANANA_WIKI_SYNC_MAPPING=
BANANA_WIKI_COMMIT_MESSAGE=docs(wiki): sync automated SDLC documentation snapshots

# Optional branch/path/label defaults for registry history PRs.
BANANA_REGISTRY_HISTORY_BRANCH=model-release-history
BANANA_REGISTRY_HISTORY_PATH=data/not-banana/model-release-history
BANANA_REGISTRY_PR_LABELS=automation,model-training,requires-human-approval
BANANA_PR_LABELS=automation,triaged-item,requires-human-approval,copilot-auto-approve,copilot-bypass-vibe-coded
BANANA_AUTONOMOUS_PR_LABELS=automation,sdlc,triaged-item,copilot-auto-approve,copilot-autonomous-cycle,copilot-bypass-vibe-coded
BANANA_TRIAGE_ISSUE_LABELS=triage-idea,copilot-suggestion,automation,copilot-bypass-vibe-coded
BANANA_TRIAGE_PR_LABELS=automation,triaged-item,requires-human-approval,copilot-auto-approve,copilot-bypass-vibe-coded
BANANA_TRIAGE_INTAKE_DIR=docs/triage/intake

# Optional restore defaults for rehydrating source-controlled model history.
BANANA_REGISTRY_RESTORE_SNAPSHOT=latest
BANANA_REGISTRY_RESTORE_RELEASE_IDS=
BANANA_REGISTRY_RESTORE_OVERWRITE=true
BANANA_REGISTRY_RESTORE_OUTPUT_ROOT=artifacts
