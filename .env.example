# Banana v2 environment template
# Copy to .env (gitignored) and fill in.

# === Hard runtime contract (specs 006/007/008) ===
# Postgres connection consumed by native DAL + ASP.NET. Absence => DbNotConfigured.
BANANA_PG_CONNECTION=host=localhost port=5432 user=cinterop password=cinterop dbname=cinterop

# Path to libbanana_native.so / banana_native.dll for ASP.NET interop loader.
BANANA_NATIVE_PATH=./build/native/Release

# Prisma 7 (TypeScript API) — consumed via prisma.config.ts.
DATABASE_URL=postgresql://cinterop:cinterop@localhost:5432/cinterop

# Compile-time injection for Vite/React (spec 009).
VITE_BANANA_API_BASE_URL=http://localhost:8080

# === Mobile / WSL2 (spec 011) ===
# Distro selection order: BANANA_WSL_DISTRO -> Ubuntu-24.04 -> Ubuntu.
BANANA_WSL_DISTRO=Ubuntu-24.04

# === Automation / GH CLI (spec 013) ===
# BANANA_PR_LABELS=sdlc,feedback-loop
# BANANA_AUTOMATION_PAT=ghp_xxx
