# Copy this file to .env and fill in real values for local workflow-container runs.
# Docker Compose in this repo auto-loads .env from the repository root.

# Required for real PR creation in local workflow containers.
GH_TOKEN=

# Set to false for real PR creation; true keeps dry-run mode.
BANANA_LOCAL_DRY_RUN=false

# Reviewer assignment (GitHub usernames only; supports comma-separated or [array] syntax).
BANANA_REGISTRY_PR_REVIEWERS=LahkLeKey,Zephyr,copilot
BANANA_PR_REVIEWERS=["LahkLeKey","Zephyr","copilot"]

# Optional PR routing defaults.
BANANA_REGISTRY_PR_BASE_BRANCH=main
BANANA_REGISTRY_OPEN_DRAFT_PR=true
BANANA_DRAFT_PR=true

# Optional branch/path/label defaults for registry history PRs.
BANANA_REGISTRY_HISTORY_BRANCH=model-release-history
BANANA_REGISTRY_HISTORY_PATH=data/not-banana/model-release-history
BANANA_REGISTRY_PR_LABELS=automation,model-training,requires-human-approval
BANANA_PR_LABELS=automation,triaged-item,requires-human-approval

# Optional restore defaults for rehydrating source-controlled model history.
BANANA_REGISTRY_RESTORE_SNAPSHOT=latest
BANANA_REGISTRY_RESTORE_RELEASE_IDS=
BANANA_REGISTRY_RESTORE_OVERWRITE=true
BANANA_REGISTRY_RESTORE_OUTPUT_ROOT=artifacts
