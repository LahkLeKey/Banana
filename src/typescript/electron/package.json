{
    "name": "@banana/electron",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "main.js",
    "scripts": {
        "dev": "electron .",
        "build": "electron-builder --win dir --x64 --publish never",
        "build:steam-candidate": "electron-builder --win dir --x64 --publish never -c.directories.output=../../../artifacts/steam-build/dev-candidate"
    },
    "devDependencies": {
        "electron": "^31.7.7",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.banana.engineer",
        "productName": "BananaEngineer",
        "files": [
            "main.js",
            "package.json"
        ],
        "asar": true,
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "dir"
            ],
            "artifactName": "BananaEngineer-${version}-${arch}.${ext}"
        }
    }
}