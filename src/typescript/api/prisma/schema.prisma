generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model BananaApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model BananaCalculation {
    id         BigInt   @id @default(autoincrement())
    purchases  Int
    multiplier Int
    banana     Int
    message    String
    source     String
    createdAt  DateTime @default(now())
}

model BatchApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model RipenessApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model MlApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model NotBananaApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model NotBananaClassification {
    id                   BigInt   @id @default(autoincrement())
    classification       String
    bananaProbability    Float
    notBananaProbability Float
    junkConfidence       Float
    actorCount           Int
    entityCount          Int
    requestJson          String
    responseJson         String
    source               String
    createdAt            DateTime @default(now())
}
