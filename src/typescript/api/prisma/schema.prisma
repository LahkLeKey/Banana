generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model BananaApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model BananaCalculation {
    id         BigInt   @id @default(autoincrement())
    purchases  Int
    multiplier Int
    banana     Int
    message    String
    source     String
    createdAt  DateTime @default(now())
}

model BatchApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model RipenessApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}

model MlApiCall {
    id           BigInt   @id @default(autoincrement())
    route        String
    statusCode   Int
    requestJson  String
    responseJson String
    createdAt    DateTime @default(now())
}
