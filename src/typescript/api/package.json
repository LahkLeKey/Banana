{
    "name": "@banana/api",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "start": "bun run src/index.ts",
        "build": "bun build src/index.ts --target=bun --outdir=dist",
        "parity:inventory": "bash ../../scripts/validate-api-parity-governance.sh --inventory-only",
        "parity:validate": "bash ../../scripts/validate-api-parity-governance.sh --strict",
        "prisma:generate": "bunx prisma generate --schema prisma/schema.prisma",
        "prisma:migrate:status": "bunx prisma migrate status --schema prisma/schema.prisma",
        "prisma:migrate:dev": "bunx prisma migrate dev --schema prisma/schema.prisma",
        "prisma:migrate:deploy": "bunx prisma migrate deploy --schema prisma/schema.prisma",
        "test": "bun test"
    },
    "dependencies": {
        "@fastify/helmet": "^13.0.2",
        "@prisma/client": "^7.0.0",
        "fastify": "^5.0.0",
        "pg-boss": "^12.18.2",
        "prisma": "^7.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.5.0"
    }
}