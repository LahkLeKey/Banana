# Fastify API gateway host/port
BANANA_API_HOST=0.0.0.0
BANANA_API_PORT=8180

# Domain API ports when run as standalone services
BANANA_BANANA_API_PORT=8181
BANANA_BATCH_API_PORT=8182
BANANA_RIPENESS_API_PORT=8183
BANANA_ML_API_PORT=8184

# Legacy ASP.NET upstream used by proxy domain services during migration
BANANA_LEGACY_API_BASE_URL=http://localhost:8080

# Optional dedicated upstream for ML routes (defaults to BANANA_LEGACY_API_BASE_URL)
BANANA_LEGACY_ML_API_BASE_URL=http://localhost:8080

# Banana domain execution mode: auto|native|proxy
BANANA_BANANA_DOMAIN_MODE=auto

# Batch domain execution mode: auto|native|proxy
BANANA_BATCH_DOMAIN_MODE=auto

# Prisma connection for request log persistence
DATABASE_URL=postgresql://cinterop:cinterop@localhost:5432/cinterop
