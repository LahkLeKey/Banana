# DX12 playloop script: scaffold lifecycle coverage
test.step bootstrap dx12 client scaffold fixture
test.use dx12-client-scaffold

expect.toHaveMetric scaffold-last-status eq 0
expect.toHaveMetric scaffold-abi-version eq 3
expect.toHaveMetric scaffold-chunk-estimate gt 0
expect.toHaveMetric scaffold-chunk-serialized gt 0
expect.toHaveMetric scaffold-launch-decided eq 1
expect.toHaveMetric scaffold-launch-allow eq 1
expect.toHaveMetric scaffold-launch-reason eq 0
expect.toHaveMetric scaffold-ui-written eq 1
expect.toHaveMetric scaffold-ui-host eq 3
expect.toHaveMetric scaffold-ui-status eq 1
expect.toHaveMetric scaffold-ui-movement eq 0
expect.toHaveMetric scaffold-ui-css-width eq 1920
expect.toHaveMetric scaffold-ui-css-height eq 1080

client.world.cleanup
note dx12_client_scaffold_smoke_validated
