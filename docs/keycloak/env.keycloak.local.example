# Copy this file to .env.keycloak.local and fill secrets for local Keycloak realm automation.

# Keycloak admin credentials for local container
KEYCLOAK_ADMIN=zephrym
KEYCLOAK_ADMIN_PASSWORD=change-me

# GitHub identity provider credentials (required for GitHub broker login)
BANANA_KEYCLOAK_IDP_GITHUB_CLIENT_ID=
BANANA_KEYCLOAK_IDP_GITHUB_CLIENT_SECRET=

# Optional for future provider enablement
BANANA_KEYCLOAK_IDP_GOOGLE_CLIENT_ID=
BANANA_KEYCLOAK_IDP_GOOGLE_CLIENT_SECRET=
BANANA_KEYCLOAK_IDP_LINKEDIN_CLIENT_ID=
BANANA_KEYCLOAK_IDP_LINKEDIN_CLIENT_SECRET=
