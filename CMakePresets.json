{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Banana Default",
            "description": "Default local configure preset for Banana native targets.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/cmake-tools",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "linux-x86_64-release",
            "displayName": "Linux x86_64 Release",
            "description": "Spec #074: Release build for linux/x86_64.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/linux-x86_64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BANANA_TRIPLE": "linux-x86_64"
            },
            "installDir": "${sourceDir}/out/native/linux-x86_64"
        },
        {
            "name": "linux-arm64-release",
            "displayName": "Linux arm64 Release",
            "description": "Spec #074: Cross-compile release build for linux/arm64.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/linux-arm64-release",
            "environment": {
                "CC": "aarch64-linux-gnu-gcc",
                "CXX": "aarch64-linux-gnu-g++"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_SYSTEM_NAME": "Linux",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64",
                "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
                "BANANA_TRIPLE": "linux-arm64"
            },
            "installDir": "${sourceDir}/out/native/linux-arm64"
        },
        {
            "name": "macos-arm64-release",
            "displayName": "macOS arm64 Release",
            "description": "Spec #074: Release build for macos/arm64.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/macos-arm64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "BANANA_TRIPLE": "macos-arm64"
            },
            "installDir": "${sourceDir}/out/native/macos-arm64"
        },
        {
            "name": "windows-x86_64-release",
            "displayName": "Windows x86_64 Release",
            "description": "Spec #074: Release build for windows/x86_64.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/windows-x86_64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_SYSTEM_NAME": "Windows",
                "BANANA_TRIPLE": "windows-x86_64"
            },
            "installDir": "${sourceDir}/out/native/windows-x86_64"
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "linux-x86_64-release",
            "configurePreset": "linux-x86_64-release"
        },
        {
            "name": "linux-arm64-release",
            "configurePreset": "linux-arm64-release"
        },
        {
            "name": "macos-arm64-release",
            "configurePreset": "macos-arm64-release"
        },
        {
            "name": "windows-x86_64-release",
            "configurePreset": "windows-x86_64-release"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}