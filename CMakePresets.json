{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Banana Default",
            "description": "Default local configure preset for Banana native targets.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/cmake-tools",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "linux-x86_64-release",
            "displayName": "Linux x86_64 Release",
            "description": "Release build preset for Linux x86_64 CI.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/linux-x86_64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/native/linux-x86_64"
            }
        },
        {
            "name": "linux-arm64-release",
            "displayName": "Linux ARM64 Release",
            "description": "Release build preset for Linux ARM64 cross-compile CI.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/linux-arm64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/native/linux-arm64"
            }
        },
        {
            "name": "macos-arm64-release",
            "displayName": "macOS ARM64 Release",
            "description": "Release build preset for macOS ARM64 CI.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/macos-arm64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/native/macos-arm64"
            }
        },
        {
            "name": "windows-x86_64-release",
            "displayName": "Windows x86_64 Release",
            "description": "Release build preset for Windows x86_64 CI.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native/windows-x86_64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/native/windows-x86_64"
            }
        },
        {
            "name": "sanitizers",
            "displayName": "Banana ASAN+UBSAN",
            "description": "AddressSanitizer + UndefinedBehaviorSanitizer preset (feature 073). Linux/macOS only.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/sanitizers",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "BANANA_ENABLE_SANITIZERS": "ON",
                "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -g",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "linux-x86_64-release",
            "configurePreset": "linux-x86_64-release"
        },
        {
            "name": "linux-arm64-release",
            "configurePreset": "linux-arm64-release"
        },
        {
            "name": "macos-arm64-release",
            "configurePreset": "macos-arm64-release"
        },
        {
            "name": "windows-x86_64-release",
            "configurePreset": "windows-x86_64-release"
        },
        {
            "name": "sanitizers",
            "configurePreset": "sanitizers"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "sanitizers",
            "configurePreset": "sanitizers",
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "ASAN_OPTIONS": "detect_leaks=1:abort_on_error=1",
                "UBSAN_OPTIONS": "print_stacktrace=1:abort_on_error=1"
            }
        }
    ]
}
