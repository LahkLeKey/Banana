                            "raw": "{{baseUrl}}/chat/sessions/:sessionId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "chat",
                                "sessions",
                                ":sessionId"
                            ],
                            "variable": [
                                {
                                    "key": "sessionId",
                                    "value": "chat_example123"
                                }
                            ]
                        },
                        "description": "Returns session metadata and full message history."
                    }
                },
                {
                    "name": "POST /chat/sessions/:sessionId/messages",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"content\": \"Is this a banana?\",\n  \"clientMessageId\": \"msg_001\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/chat/sessions/:sessionId/messages",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "chat",
                                "sessions",
                                ":sessionId",
                                "messages"
                            ],
                            "variable": [
                                {
                                    "key": "sessionId",
                                    "value": "chat_example123"
                                }
                            ]
                        },
                        "description": "Appends a user message and returns the deterministic banana-signal reply. Supports idempotent delivery via clientMessageId."
                    }
                }
            ]
        },
