{
    "info": {
        "_postman_id": "banana-api-v1",
        "name": "Banana API",
        "description": "Banana classification, ripeness prediction, ML ensemble, chat, harvest, truck, workbench training, audit, and streaming endpoints.\n\nBase URL: `{{baseUrl}}` — set this variable to your target environment, e.g. `https://api.banana.engineer` or `http://localhost:5000`.\n\nFor JWT-protected routes set the `token` collection variable to a valid Bearer token.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "https://api.banana.engineer",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "GET /health",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/health",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "health"
                            ]
                        },
                        "description": "Liveness probe. Returns `{\"status\":\"ok\"}`."
                    }
                }
            ]
        },
        {
            "name": "Banana",
            "item": [
                {
                    "name": "GET /banana",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/banana?purchases=5&multiplier=2",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "banana"
                            ],
                            "query": [
                                {
                                    "key": "purchases",
                                    "value": "5",
                                    "description": "Number of banana purchases"
                                },
                                {
                                    "key": "multiplier",
                                    "value": "2",
                                    "description": "Score multiplier (default 1)"
                                }
                            ]
                        },
                        "description": "Calculates banana total with purchase bonus breakdown."
                    }
                }
            ]
        },
        {
            "name": "ML",
            "item": [
                {
                    "name": "POST /ml/regression",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"inputJson\": \"{\\\"sample\\\":\\\"yellow curved fruit with a sweet smell\\\"}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/ml/regression",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "ml",
                                "regression"
                            ]
                        },
                        "description": "Runs the native regression model. Returns `{score: double}`."
                    }
                },
                {
                    "name": "POST /ml/binary",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"inputJson\": \"{\\\"sample\\\":\\\"yellow curved fruit with a sweet smell\\\"}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/ml/binary",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "ml",
                                "binary"
                            ]
                        },
                        "description": "Binary banana/not-banana classification. Returns label and score."
                    }
                },
                {
                    "name": "POST /ml/transformer",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"inputJson\": \"{\\\"sample\\\":\\\"yellow curved fruit with a sweet smell\\\"}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/ml/transformer",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "ml",
                                "transformer"
                            ]
                        },
                        "description": "Full Brain transformer classification. Returns 4-class label, score, and embedding."
                    }
                },
                {
                    "name": "POST /ml/ensemble",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"inputJson\": \"{\\\"sample\\\":\\\"yellow curved fruit with a sweet smell\\\"}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/ml/ensemble",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "ml",
                                "ensemble"
                            ]
                        },
                        "description": "Gated cascade ensemble (input validation → gating → escalation → calibration). Returns composite EnsembleVerdictResult."
                    }
                },
                {
                    "name": "POST /ml/ensemble/embedding",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"inputJson\": \"{\\\"sample\\\":\\\"yellow curved fruit with a sweet smell\\\"}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/ml/ensemble/embedding",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "ml",
                                "ensemble",
                                "embedding"
                            ]
                        },
                        "description": "Same as /ml/ensemble but also returns the 4-dim transformer embedding fingerprint when the cascade escalated."
                    }
                }
            ]
        },
